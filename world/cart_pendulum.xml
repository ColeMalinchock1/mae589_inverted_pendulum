<mujoco model="cart_pendulum">
    <worldbody>
        <body name="cart" pos="0 0 0">
            <joint name="slider" type="slide" axis="1 0 0" />
            <geom name="cart_geom" type="box" size="0.5 0.2 0.1" density="1000" />
            <body name="pole" pos="0 0 0.1">
                <joint name="hinge" type="hinge" axis="0 1 0" />
                <geom name="pole_geom" type="capsule" fromto="0 0 0 0 0 1" size="0.05" density="1000" />
            </body>
        </body>
    </worldbody>
</mujoco>